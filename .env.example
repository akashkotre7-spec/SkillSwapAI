# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# MONGODB_URI: MongoDB Atlas connection string (e.g., mongodb+srv://...)
MONGODB_URI=""

# JWT_SECRET: Secret for signing auth tokens
JWT_SECRET="skillswap_secret_key_change_in_production"

# Monitoring & Error Tracking
VITE_SENTRY_DSN=""

# Cloudinary Configuration for Image Uploads
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET="ml_default"

# OAuth Configuration (Handled via Firebase)
# Ensure Google & GitHub providers are enabled in Firebase Console.
